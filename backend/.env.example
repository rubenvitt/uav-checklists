# ============================================
# UAV Signing Backend - Environment Variables
# ============================================
# Copy this file to .env and adjust values

# --- API Gateway ---
API_PORT=3001
CORS_ORIGIN=http://localhost:5173

# --- OIDC Authentication ---
# Leave empty for dev mode (no auth required)
OIDC_ISSUER=
OIDC_CLIENT_ID=

# --- Signer Service ---
# Password for the PKCS#12 (.p12) signing certificate
SIGNER_CERT_PASSWORD=changeme

# RFC 3161 Timestamp Authority URL
SIGNER_TSA_URL=http://timestamp.digicert.com
